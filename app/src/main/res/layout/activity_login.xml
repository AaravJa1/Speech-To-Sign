<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="#0A0A0A"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="SYSTEM_LOGIN"
    android:textSize="36sp"
    android:textStyle="bold"
    android:textColor="#03DAC5"
    android:fontFamily="monospace"
    android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="USER_IDENTIFICATION (Email)"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:inputType="textEmailAddress"
        android:backgroundTint="#FF007F"
        android:fontFamily="monospace"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="SECURITY_KEY (Password)"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:inputType="textPassword"
        android:backgroundTint="#FF007F"
        android:fontFamily="monospace"
        android:minHeight="48dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="INITIATE LOGIN"
        android:textColor="#000000"
        android:textStyle="bold"
        android:fontFamily="monospace"
        app:backgroundTint="#03DAC5"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="REGISTER NEW ENTITY"
        android:textColor="#FF007F"
        android:fontFamily="monospace"
        style="?attr/materialButtonOutlinedStyle"
        app:strokeColor="#FF007F"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--- OR ---"
        android:textColor="#555555"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnGoogleSignIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BYPASS WITH GOOGLE"
        android:textColor="#FFFFFF"
        android:fontFamily="monospace"
        app:icon="@android:drawable/ic_menu_myplaces"
        app:iconTint="#FFFFFF"
        app:backgroundTint="#4285F4" /> </LinearLayout>