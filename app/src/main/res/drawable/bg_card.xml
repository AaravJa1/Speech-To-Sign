<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bg_card.xml -->
<!-- Semi-transparent dark card with a subtle border — glass-morphism style -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#1A12141F" />
    <stroke
        android:width="1dp"
        android:color="#20FFFFFF" />      <!-- very subtle white border -->
    <corners android:radius="20dp" />

</shape>